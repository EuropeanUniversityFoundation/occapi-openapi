{
  "name": "acme-api",
  "version": "1.0.0",
  "dependencies": {
    "@redocly/cli": "^2.0.8",
    "npm-watch": "^0.13.0"
  },
  "private": true,
  "watch": {
    "build": {
      "patterns": [
        "openapi"
      ],
      "extensions": "yaml,md",
      "quiet": true,
      "legacyWatch": true
    }
  },
  "scripts": {
    "start": "npm-watch",
    "build": "redocly bundle",
    "postbuild": "./postbuild.sh",
    "test": "redocly lint",
    "watch": "npm-watch"
  }
}
